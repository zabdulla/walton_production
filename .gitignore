# Exclude Excel files at project root
/*.xlsx

# Raw processing reports (large data files)
processing_reports/

# Payroll PDF source files (do not commit sensitive employee data)
data/*.pdf
data/payroll_pdfs/
data/aggregated_payroll.xlsx

# Generated artifacts (can be regenerated)
auto_generated_graphs/
Meeting_Plots/

# Local-only reports (operator dashboard, etc.)
reports/

# Python cache
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# Virtual environments
venv/
.venv/
env/

# OS files
.DS_Store
Thumbs.db

# IDE/Editor
.claude/
.vscode/
.idea/
*.swp

# Temporary files
*.tmp
*~

# Logs from the weekly update orchestrator (keep dir, ignore content)
logs/*.log
!logs/.gitkeep
